# Supabase — get from https://supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# AI — Groq (free, no credit card) — get key at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# Stripe (optional — only needed for paid plans)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=

# CORS — set to your Vercel frontend URL in Railway
FRONTEND_URL=https://your-app.vercel.app
